{
  "name": "expopilot-os",
  "private": true,
  "version": "2.0.0-mvp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:copy": "node ./scripts/check-copy.mjs",
    "test:state": "node ./scripts/test-state-machine.mjs",
    "test:contract": "node ./scripts/check-contract.mjs",
    "test:agent": "node ./server/eval/run-eval.mjs",
    "server:demo": "node ./server/index.mjs",
    "test:ui": "node --experimental-strip-types ./scripts/test-ui-services.mts",
    "release:demo": "npm run build && node ./scripts/prepare-demo-release.mjs",
    "cli": "node ./scripts/expopilot.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
