.worker-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(255, 138, 42, 0.16), transparent 32%),
    linear-gradient(180deg, #0d0c0b 0%, #050505 100%);
}

.topbar,
.task-card,
.panel {
  border: 1rpx solid rgba(255, 138, 42, 0.16);
  border-radius: 28rpx;
  background: rgba(18, 17, 16, 0.88);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.28);
}

.topbar {
  min-height: 112rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow,
.section-head text:first-child,
.status-row text:first-child,
.source-box text:first-child {
  color: rgba(255, 248, 243, 0.55);
  font-size: 24rpx;
  font-weight: 700;
}

.operator {
  margin-top: 8rpx;
  display: block;
  color: #fff8f3;
  font-size: 34rpx;
  font-weight: 900;
}

.online,
.status-pill {
  padding: 10rpx 18rpx;
  color: #ffd08a;
  border: 1rpx solid rgba(255, 138, 42, 0.32);
  border-radius: 999rpx;
  background: rgba(255, 138, 42, 0.12);
  font-size: 24rpx;
  font-weight: 900;
}

.task-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.status-row,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.task-title {
  margin-top: 24rpx;
  display: block;
  color: #fff8f3;
  font-size: 48rpx;
  font-weight: 950;
  line-height: 1.12;
}

.task-desc {
  margin-top: 14rpx;
  display: block;
  color: rgba(255, 248, 243, 0.68);
  font-size: 26rpx;
  line-height: 1.55;
}

.meta-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-grid view,
.source-box {
  min-height: 104rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.045);
}

.meta-grid text:first-child {
  display: block;
  color: rgba(255, 248, 243, 0.5);
  font-size: 22rpx;
}

.meta-grid text:last-child,
.source-box text:last-child {
  margin-top: 8rpx;
  display: block;
  color: #fff8f3;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.35;
}

.source-box {
  margin-top: 16rpx;
}

.panel {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-head text:last-child {
  color: #ffd08a;
  font-size: 24rpx;
  font-weight: 850;
}

.instruction {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: rgba(255, 248, 243, 0.82);
  font-size: 28rpx;
  line-height: 1.4;
}

.index,
.dot {
  width: 42rpx;
  height: 42rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  color: #050505;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd08a, #ff8a2a);
  font-size: 22rpx;
  font-weight: 950;
}

.button-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.command-button,
.reset-button {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 248, 243, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.055);
  font-size: 28rpx;
  font-weight: 900;
}

.command-button.primary {
  color: #120b05;
  background: linear-gradient(135deg, #ffd08a, #ff8a2a 55%, #c85a1e);
}

.command-button.secondary {
  color: #ffd08a;
  border-color: rgba(255, 138, 42, 0.3);
}

.command-button.danger {
  color: #ffe4d2;
  border-color: rgba(255, 83, 42, 0.45);
  background: rgba(255, 83, 42, 0.12);
}

.alert {
  margin-top: 18rpx;
  display: block;
  color: #ffd08a;
  font-size: 25rpx;
  line-height: 1.45;
}

.result-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-list text {
  padding: 12rpx 16rpx;
  color: #ffd08a;
  border: 1rpx solid rgba(255, 138, 42, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 138, 42, 0.08);
  font-size: 24rpx;
}

.note {
  width: 100%;
  min-height: 150rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #fff8f3;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.055);
  font-size: 26rpx;
  line-height: 1.5;
}

.timeline-item {
  margin-top: 20rpx;
  display: flex;
  gap: 18rpx;
  color: rgba(255, 248, 243, 0.58);
}

.timeline-item.current {
  color: #ffd08a;
}

.timeline-item.done {
  color: rgba(255, 248, 243, 0.88);
}

.timeline-item view text:first-child {
  display: block;
  font-size: 28rpx;
  font-weight: 850;
}

.timeline-item view text:last-child {
  margin-top: 6rpx;
  display: block;
  font-size: 23rpx;
}

.reset-button {
  width: 100%;
  margin-top: 24rpx;
}
